# .env.local
# Copy this file to .env.local and fill in values.

# Leave empty for MVP local mode (no backend needed).
# Set to your FastAPI URL when backend is ready.
NEXT_PUBLIC_API_URL=

# Internal: server-side FastAPI URL (used by Next.js API route proxy).
# Only needed if you use /api/analyze as a proxy layer.
FASTAPI_URL=
